{
  "name": "calsnap-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:android": "vite build",
    "ai-scan-server": "node ./server/ai-scan-proxy.mjs",
    "firebase:login": "npx firebase-tools login",
    "firebase:functions:install": "npm --prefix functions install",
    "firebase:secret:gemini": "npx firebase-tools functions:secrets:set GEMINI_API_KEY --project calsnap-ai-82070",
    "firebase:deploy": "npm run build && npm run firebase:functions:install && npx firebase-tools deploy --project calsnap-ai-82070 --only functions:aiScanFood,hosting",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "tsx --test src/services/appData.test.ts src/services/authFeedback.test.ts src/services/backup.test.ts src/services/foodScaling.test.ts src/services/localNutrition.test.ts src/services/premiumFeatures.test.ts src/services/adaptiveTargets.test.ts src/services/barcode.test.ts src/services/healthConnect.test.ts src/services/mealQuality.test.ts"
  },
  "dependencies": {
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^7.6.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
